<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yedam.app.project.mapper.ProjectMapper">
	<select id="selectAll" resultType="ProjectVO">
		SELECT p.project_code
		,p.project_name
		,p.description
		,p.created_on
		,c.code_name
		,p.user_code
		,u.name
		,u.phone
		,u.email
		FROM projects p
		JOIN common_code c ON p.status = c.code_id
		JOIN users u
		ON p.user_code = u.user_code
		ORDER BY p.project_name
	</select>

	<select id="roleAll" resultType="RoleVO">
		SELECT
		role_code
		,role_name
		,explanation
		FROM role
	</select>
	<select id="userAll" resultType="PruserVO">
		SELECT
		user_code
		,employee_no
		,name
		,phone
		,email
		,created_at
		,is_lock
		FROM users
	</select>
	
	<select id="groupAll" resultType="GroupVO">
		SELECT 
		    group_code,
		    gr_name,
		    description
		FROM "GROUP"
	</select>
</mapper>
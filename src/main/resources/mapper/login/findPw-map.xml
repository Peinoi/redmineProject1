<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yedam.app.login.mapper.FindPwMapper">
	<select id="selectFindPwInfo" resultType="FindPwVO">
		select email
				,name
				,phone
		from users
		where email = #{email}
		and name = #{name}
		and phone = #{phone}
	</select>
</mapper>